direction: right

title: |md
  ## Phase Dependencies & Critical Path
| {
  near: top-center
  shape: text
  style.font-size: 18
}

classes: {
  phase: {
    shape: rectangle
    style.border-radius: 6
    style.stroke-width: 2
    style.font-size: 10
  }
  label: {
    shape: text
    style.font-size: 11
  }
}

# Timeline header
weeks: |md
  **Wk 0-2** → **Wk 3-4** → **Wk 5-7** → **Wk 8** → **Wk 9** → **Wk 10-12**
| {
  shape: text
  style.font-size: 10
  style.font-color: "#6b7280"
  near: top-center
}

# Critical Path (top row)
critical-label: "Critical Path:" {
  shape: text
  style.font-size: 11
  style.font-color: "#dc2626"
  style.bold: true
}

P0: |md
  **P0**
  Design
| {
  class: phase
  style.stroke: "#6366f1"
  style.fill: "#eef2ff"
}

P2: |md
  **P2**
  Data Found.
| {
  class: phase
  style.stroke: "#7c3aed"
  style.fill: "#f5f3ff"
}

P3: |md
  **P3**
  Agent Core
| {
  class: phase
  style.stroke: "#f59e0b"
  style.fill: "#fffbeb"
}

P5: |md
  **P5**
  Integration
| {
  class: phase
  style.stroke: "#0ea5e9"
  style.fill: "#f0f9ff"
}

P6: |md
  **P6**
  Pilot
| {
  class: phase
  style.stroke: "#ec4899"
  style.fill: "#fdf2f8"
}

# Parallel Path (bottom row)
parallel-label: "Parallel:" {
  shape: text
  style.font-size: 11
  style.font-color: "#059669"
  style.bold: true
}

P1: |md
  **P1**
  Mobilize
| {
  class: phase
  style.stroke: "#059669"
  style.fill: "#ecfdf5"
}

P4: |md
  **P4**
  Measure
| {
  class: phase
  style.stroke: "#10b981"
  style.fill: "#ecfdf5"
}

# Layout containers to force two rows
top-row: {
  style.fill: transparent
  style.stroke: transparent
  direction: right

  critical-label
  P0
  P2
  P3
  P5
  P6
}

bottom-row: {
  style.fill: transparent
  style.stroke: transparent
  direction: right

  parallel-label
  P1
  spacer1: "" { style.opacity: 0 }
  P4
  spacer2: "" { style.opacity: 0 }
  spacer3: "" { style.opacity: 0 }
}

# Critical path arrows
top-row.P0 -> top-row.P2: {
  style.stroke: "#dc2626"
  style.stroke-width: 3
}
top-row.P2 -> top-row.P3: {
  style.stroke: "#dc2626"
  style.stroke-width: 3
}
top-row.P3 -> top-row.P5: {
  style.stroke: "#dc2626"
  style.stroke-width: 3
}
top-row.P5 -> top-row.P6: {
  style.stroke: "#dc2626"
  style.stroke-width: 3
}

# Parallel merge arrows
top-row.P0 -> bottom-row.P1: {
  style.stroke: "#6b7280"
  style.stroke-width: 2
}
bottom-row.P1 -> top-row.P2: {
  style.stroke: "#6b7280"
  style.stroke-width: 2
}
top-row.P2 -> bottom-row.P4: {
  style.stroke: "#6b7280"
  style.stroke-width: 2
}
bottom-row.P4 -> top-row.P5: {
  style.stroke: "#6b7280"
  style.stroke-width: 2
}
