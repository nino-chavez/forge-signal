direction: down

title: |md
  ## Phase Dependencies & Critical Path
| {
  near: top-center
  shape: text
  style.font-size: 18
}

classes: {
  phase: {
    shape: rectangle
    style.border-radius: 8
    style.stroke-width: 2
    style.font-size: 11
  }
  critical-arrow: {
    style.stroke: "#dc2626"
    style.stroke-width: 3
  }
  parallel-arrow: {
    style.stroke: "#6b7280"
    style.stroke-width: 2
    style.stroke-dash: 4
  }
}

# Critical Path Container - forces horizontal layout
critical: Critical Path {
  grid-rows: 1
  grid-columns: 5
  grid-gap: 16

  style.fill: transparent
  style.stroke: transparent
  style.font-color: "#dc2626"
  style.font-size: 12

  P0: |md
    **P0**
    Design
    Wk 0-2
  | {
    class: phase
    style.stroke: "#6366f1"
    style.fill: "#eef2ff"
    style.font-color: "#4338ca"
  }

  P2: |md
    **P2**
    Data Foundation
    Wk 3-4
  | {
    class: phase
    style.stroke: "#7c3aed"
    style.fill: "#f5f3ff"
    style.font-color: "#5b21b6"
  }

  P3: |md
    **P3**
    Agent Core
    Wk 5-7
  | {
    class: phase
    style.stroke: "#f59e0b"
    style.fill: "#fffbeb"
    style.font-color: "#b45309"
  }

  P5: |md
    **P5**
    Integration
    Wk 9
  | {
    class: phase
    style.stroke: "#0ea5e9"
    style.fill: "#f0f9ff"
    style.font-color: "#0369a1"
  }

  P6: |md
    **P6**
    Pilot
    Wk 10-12
  | {
    class: phase
    style.stroke: "#ec4899"
    style.fill: "#fdf2f8"
    style.font-color: "#be185d"
  }

  # Critical path connections
  P0 -> P2: { class: critical-arrow }
  P2 -> P3: { class: critical-arrow }
  P3 -> P5: { class: critical-arrow }
  P5 -> P6: { class: critical-arrow }
}

# Parallel Path Container
parallel: Parallel Paths (must complete before P6) {
  grid-rows: 1
  grid-columns: 2
  grid-gap: 80
  horizontal-gap: 200

  style.fill: transparent
  style.stroke: transparent
  style.font-color: "#6b7280"
  style.font-size: 12

  P1: |md
    **P1**
    Mobilization
    Wk 2
  | {
    class: phase
    style.stroke: "#059669"
    style.fill: "#ecfdf5"
    style.font-color: "#047857"
  }

  P4: |md
    **P4**
    Measurement
    Wk 8
  | {
    class: phase
    style.stroke: "#10b981"
    style.fill: "#ecfdf5"
    style.font-color: "#047857"
  }
}

# Cross-container dependency arrows
critical.P0 -> parallel.P1: { class: parallel-arrow }
parallel.P1 -> critical.P2: { class: parallel-arrow }
critical.P2 -> parallel.P4: { class: parallel-arrow }
parallel.P4 -> critical.P5: { class: parallel-arrow }
