direction: right

title: |md
  # 10-Week Implementation Roadmap
  7-Week Build + 3-Week Pilot Measurement
| {
  near: top-center
  shape: text
  style.font-size: 24
}

# Timeline
timeline: {
  shape: rectangle
  style.fill: transparent
  style.stroke: transparent

  weeks: {
    shape: rectangle
    style.fill: transparent
    style.stroke: "#6b7280"
    style.stroke-width: 2

    w0: "0" { style.fill: transparent; style.stroke: transparent }
    w1: "1" { style.fill: transparent; style.stroke: transparent }
    w2: "2" { style.fill: transparent; style.stroke: transparent }
    w3: "3" { style.fill: transparent; style.stroke: transparent }
    w4: "4" { style.fill: transparent; style.stroke: transparent }
    w5: "5" { style.fill: transparent; style.stroke: transparent }
    w6: "6" { style.fill: transparent; style.stroke: transparent }
    w7: "7" { style.fill: transparent; style.stroke: transparent }
    w8: "8" { style.fill: transparent; style.stroke: transparent }
    w9: "9" { style.fill: transparent; style.stroke: transparent }
    w10: "10" { style.fill: transparent; style.stroke: transparent }
  }
}

# Build Phase Box
build: BUILD PHASE (Wks 0-7) {
  style.fill: "#dbeafe"
  style.stroke: "#3b82f6"
  style.font-color: "#1d4ed8"
  style.font-size: 12
}

# Pilot Phase Box
pilot: PILOT MEASUREMENT (Wks 7-10) {
  style.fill: "#dcfce7"
  style.stroke: "#22c55e"
  style.font-color: "#15803d"
  style.font-size: 12
}

# Phase Bars
p0: P0: Mobilization {
  style.fill: "#6366f1"
  style.stroke: "#6366f1"
  style.font-color: white
  style.border-radius: 5
}

p1: P1: Data Foundation (Wk 1-3) {
  style.fill: "#7c3aed"
  style.stroke: "#7c3aed"
  style.font-color: white
  style.border-radius: 5
}

p2: P2: Agent Core (Wk 2-5) {
  style.fill: "#f59e0b"
  style.stroke: "#f59e0b"
  style.font-color: white
  style.border-radius: 5
}

p3: P3: Measurement (Wk 4-6) {
  style.fill: "#10b981"
  style.stroke: "#10b981"
  style.font-color: white
  style.border-radius: 5
}

p4: P4: Integration & Polish (Wk 5-7) {
  style.fill: "#0ea5e9"
  style.stroke: "#0ea5e9"
  style.font-color: white
  style.border-radius: 5
}

p5: P5: Pilot Execution (Wk 7-10) {
  style.fill: "#ec4899"
  style.stroke: "#ec4899"
  style.font-color: white
  style.border-radius: 5
}

# Milestones
m0: "M0\nKickoff" {
  shape: circle
  style.fill: "#dc2626"
  style.stroke: "#dc2626"
  style.font-color: white
  style.font-size: 10
}

m1: "M1\nData Pipeline" {
  shape: circle
  style.fill: "#dc2626"
  style.stroke: "#dc2626"
  style.font-color: white
  style.font-size: 10
}

m2: "M2\nAgent Demo" {
  shape: circle
  style.fill: "#dc2626"
  style.stroke: "#dc2626"
  style.font-color: white
  style.font-size: 10
}

m3: "M3\nMeasurement" {
  shape: circle
  style.fill: "#dc2626"
  style.stroke: "#dc2626"
  style.font-color: white
  style.font-size: 10
}

m4: "M4\nSystem Ready" {
  shape: circle
  style.fill: "#dc2626"
  style.stroke: "#dc2626"
  style.font-color: white
  style.font-size: 10
}

m5: "M5\nPilot Complete" {
  shape: circle
  style.fill: "#dc2626"
  style.stroke: "#dc2626"
  style.font-color: white
  style.font-size: 10
}

# Dependencies (implicit via layout)
p0 -> p1: { style.stroke-dash: 3 }
p1 -> p2: { style.stroke-dash: 3 }
p1 -> p3: { style.stroke-dash: 3 }
p1 -> p4: { style.stroke-dash: 3 }
p2 -> p5: { style.stroke-dash: 3 }
p3 -> p5: { style.stroke-dash: 3 }
p4 -> p5: { style.stroke-dash: 3 }

# Note
note: |md
  **Note:** Pilot requires 3+ Profound scan cycles
| {
  style.fill: "#fef3c7"
  style.stroke: "#f59e0b"
  style.font-size: 11
  near: bottom-right
}
