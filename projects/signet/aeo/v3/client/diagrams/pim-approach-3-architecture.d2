direction: right

title: |md
  # Approach 3: Real-Time Embedding
  Query-Time Semantic Matching
| {
  near: top-center
  shape: text
  style.font-size: 18
}

# External Systems Zone
external: EXTERNAL SYSTEMS {
  style.fill: "#f9fafb"
  style.stroke: "#6b7280"
  style.stroke-dash: 5

  profound: {
    label: "Profound\nVisibility API"
    style.fill: "#f5f3ff"
    style.stroke: "#7c3aed"
    style.stroke-width: 2
    style.font-color: "#5b21b6"
  }

  pim: {
    label: "Infoverity PIM\n(Read/Write)"
    style.fill: "#eff6ff"
    style.stroke: "#2563eb"
    style.stroke-width: 2
    style.font-color: "#1d4ed8"
  }
}

# AWS Cloud Zone
aws: AWS CLOUD {
  style.fill: "#fff7ed"
  style.stroke: "#f97316"
  style.stroke-width: 2

  # Data Ingestion Layer
  ingestion: Data Ingestion {
    style.fill: "#ffffff"
    style.stroke: "#d1d5db"

    s3: {
      label: "S3"
      style.fill: "#f0fdf4"
      style.stroke: "#16a34a"
      style.stroke-width: 2
    }

    lambda_ingest: {
      label: "Ingestion\nLambda"
      style.fill: "#fff7ed"
      style.stroke: "#f97316"
      style.stroke-width: 2
    }

    opensearch: {
      label: "OpenSearch\n(Profound Only)"
      style.fill: "#f5f3ff"
      style.stroke: "#7c3aed"
      style.stroke-width: 2
    }
  }

  # Real-Time Processing Layer
  realtime: Real-Time Processing {
    style.fill: "#ffffff"
    style.stroke: "#d1d5db"

    category_extract: {
      label: "Category\nExtraction"
      style.fill: "#fff7ed"
      style.stroke: "#f97316"
      style.stroke-width: 2
    }

    pim_query: {
      label: "PIM Query\nLambda"
      style.fill: "#fff7ed"
      style.stroke: "#f97316"
      style.stroke-width: 2
    }

    titan_embed: {
      label: "Titan\nEmbeddings\n(Real-Time)"
      style.fill: "#f5f3ff"
      style.stroke: "#7c3aed"
      style.stroke-width: 2
    }

    similarity: {
      label: "Similarity\nCompute"
      style.fill: "#fff7ed"
      style.stroke: "#f97316"
      style.stroke-width: 2
    }
  }

  # Content Generation Layer
  content: Content Generation {
    style.fill: "#ffffff"
    style.stroke: "#d1d5db"

    bedrock: {
      label: "Bedrock\nAgent"
      style.fill: "#7c3aed"
      style.stroke: "#5b21b6"
      style.stroke-width: 2
      style.font-color: white
    }

    pim_update: {
      label: "PIM Update\nLambda"
      style.fill: "#fff7ed"
      style.stroke: "#f97316"
      style.stroke-width: 2
    }
  }
}

# Key Feature Box
key: |md
  **Key Features**
  - No SKU data stored
  - Always current data
  - Handles new SKUs
  - Higher latency (2-5s)
  - Higher compute cost
| {
  near: bottom-right
  style.fill: "#fef3c7"
  style.stroke: "#f59e0b"
  style.stroke-width: 2
  style.font-size: 11
}

# Connections
external.profound -> aws.ingestion.s3: "Visibility Data" {
  style.stroke: "#7c3aed"
  style.stroke-width: 2
}

aws.ingestion.s3 -> aws.ingestion.lambda_ingest: {
  style.stroke: "#6b7280"
  style.stroke-width: 2
}

aws.ingestion.lambda_ingest -> aws.ingestion.opensearch: {
  style.stroke: "#6b7280"
  style.stroke-width: 2
}

aws.realtime.category_extract -> aws.realtime.pim_query: "Category Hint" {
  style.stroke: "#6b7280"
  style.stroke-width: 2
}

aws.realtime.pim_query -> external.pim: "Query Candidates" {
  style.stroke: "#2563eb"
  style.stroke-width: 2
}

external.pim -> aws.realtime.pim_query: "50-500 SKUs" {
  style.stroke: "#2563eb"
  style.stroke-width: 2
}

aws.realtime.pim_query -> aws.realtime.titan_embed: "SKU Data" {
  style.stroke: "#6b7280"
  style.stroke-width: 2
}

aws.realtime.titan_embed -> aws.realtime.similarity: "Vectors" {
  style.stroke: "#7c3aed"
  style.stroke-width: 2
}

aws.realtime.similarity -> aws.content.bedrock: "Matched SKUs" {
  style.stroke: "#6b7280"
  style.stroke-width: 2
}

aws.content.bedrock -> aws.content.pim_update: {
  style.stroke: "#6b7280"
  style.stroke-width: 2
}

aws.content.pim_update -> external.pim: "REST API" {
  style.stroke: "#2563eb"
  style.stroke-width: 2
}
