# Agentic Commerce Operating System
# Style: Marriott/Accenture bubble map with Agent Lanes overlay

direction: down

title: {
  label: |md
    # Industrializing Agentic Commerce
    Systems & Data Domains by Agent Access Lane
  |
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
  }
}

# ============================================
# FUNCTIONAL DOMAIN BUBBLES (Main circles)
# ============================================

grid-rows: 3
grid-gap: 40

# ROW 1: Front-of-house domains
experience: {
  label: EXPERIENCE & SEARCH
  style: {
    fill: "#ede9fe"
    stroke: "#7c3aed"
    stroke-width: 3
    border-radius: 999
    font-size: 14
    bold: true
  }

  # Systems
  search-engine: Search Engine\n(Vector/Semantic) {
    shape: rectangle
    style: {
      fill: "#f5f3ff"
      stroke: "#a78bfa"
      font-size: 11
    }
  }
  headless-cms: Headless CMS {
    shape: rectangle
    style: {
      fill: "#f5f3ff"
      stroke: "#a78bfa"
      font-size: 11
    }
  }

  # Data Domains
  intent-graph: Intent Graph {
    shape: oval
    style: {
      fill: "#7c3aed"
      font-color: "#ffffff"
      font-size: 10
    }
  }
  sentiment: Sentiment\nTelemetry {
    shape: oval
    style: {
      fill: "#7c3aed"
      font-color: "#ffffff"
      font-size: 10
    }
  }
}

