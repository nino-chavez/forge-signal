# ============================================
# AGENT LANES (Right side indicators)
# ============================================

lanes: {
  label: AGENT ACCESS LANES
  style: {
    fill: "#f8fafc"
    stroke: "#1a365d"
    stroke-width: 2
    border-radius: 8
    font-size: 14
    bold: true
  }

  external-llm: {
    label: External LLM Agents\n(ChatGPT, Gemini, Claude)
    shape: hexagon
    style: {
      fill: "#1a365d"
      font-color: "#ffffff"
      font-size: 11
    }
  }

  brand-agent: {
    label: Brand Concierge Agent\n(Internal, Full Access)
    shape: hexagon
    style: {
      fill: "#7c3aed"
      font-color: "#ffffff"
      font-size: 11
    }
  }

  process-agent: {
    label: Process Agents\n(Fulfillment, Pricing, Service)
    shape: hexagon
    style: {
      fill: "#059669"
      font-color: "#ffffff"
      font-size: 11
    }
  }

  customer-agent: {
    label: Customer's Agent\n(Apple Intelligence, etc.)
    shape: hexagon
    style: {
      fill: "#ea580c"
      font-color: "#ffffff"
      font-size: 11
    }
  }
}

# ============================================
# AGENT LANE CONNECTIONS
# ============================================

# External LLM Agents - Public product info only
lanes.external-llm -> experience: {
  label: "Read"
  style: {
    stroke: "#1a365d"
    stroke-width: 2
    stroke-dash: 5
  }
}
lanes.external-llm -> merchandising: {
  label: "Read"
  style: {
    stroke: "#1a365d"
    stroke-width: 2
    stroke-dash: 5
  }
}
lanes.external-llm -> content: {
  label: "Read"
  style: {
    stroke: "#1a365d"
    stroke-width: 2
    stroke-dash: 5
  }
}

# Brand Concierge - Full access orchestrator
lanes.brand-agent -> experience: {
  label: "R/W"
  style: {
    stroke: "#7c3aed"
    stroke-width: 3
  }
}
lanes.brand-agent -> merchandising: {
  label: "R/W"
  style: {
    stroke: "#7c3aed"
    stroke-width: 3
  }
}
lanes.brand-agent -> supply-chain: {
  label: "R/W"
  style: {
    stroke: "#7c3aed"
    stroke-width: 3
  }
}
lanes.brand-agent -> finance: {
  label: "R/W"
  style: {
    stroke: "#7c3aed"
    stroke-width: 3
  }
}
lanes.brand-agent -> customer-service: {
  label: "R/W"
  style: {
    stroke: "#7c3aed"
    stroke-width: 3
  }
}

# Process Agents - Domain-specific automation
lanes.process-agent -> supply-chain: {
  label: "Execute"
  style: {
    stroke: "#059669"
    stroke-width: 2
  }
}
lanes.process-agent -> finance: {
  label: "Execute"
  style: {
    stroke: "#059669"
    stroke-width: 2
  }
}
lanes.process-agent -> customer-service: {
  label: "Execute"
  style: {
    stroke: "#059669"
    stroke-width: 2
  }
}

# Customer's Agent - Authenticated external
lanes.customer-agent -> experience: {
  label: "Query"
  style: {
    stroke: "#ea580c"
    stroke-width: 2
    stroke-dash: 3
  }
}
lanes.customer-agent -> supply-chain: {
  label: "Track"
  style: {
    stroke: "#ea580c"
    stroke-width: 2
    stroke-dash: 3
  }
}
lanes.customer-agent -> customer-service: {
  label: "Request"
  style: {
    stroke: "#ea580c"
    stroke-width: 2
    stroke-dash: 3
  }
}

