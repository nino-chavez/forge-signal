{
  "$schema": "playbook-config-schema.json",
  "version": "1.0.0",
  "metadata": {
    "title": "GEO Governance Playbook",
    "subtitle": "Enterprise Framework for Generative Engine Optimization",
    "version": "1.0",
    "lastUpdated": "2025-12-09",
    "author": "Signal Forge"
  },
  "variables": {
    "client": {
      "name": "{{client.name}}",
      "domain": "{{client.domain}}",
      "industry": "{{client.industry}}",
      "lob": "{{client.lob}}",
      "defaults": {
        "name": "[Client Name]",
        "domain": "[client-domain.com]",
        "industry": "Retail",
        "lob": "[Line of Business]"
      }
    },
    "technology": {
      "llm_platform": "{{tech.llm_platform}}",
      "vector_store": "{{tech.vector_store}}",
      "measurement_platform": "{{tech.measurement_platform}}",
      "commerce_platform": "{{tech.commerce_platform}}",
      "content_platform": "{{tech.content_platform}}",
      "defaults": {
        "llm_platform": "Cloud LLM Service",
        "vector_store": "Vector Database",
        "measurement_platform": "AEO Measurement Platform",
        "commerce_platform": "Commerce Platform",
        "content_platform": "Content Management System"
      },
      "options": {
        "llm_platform": ["AWS Bedrock", "Google Vertex AI", "Azure OpenAI", "Custom/Self-Hosted"],
        "vector_store": ["OpenSearch", "Pinecone", "Weaviate", "Qdrant", "Vertex AI Vector Search", "Azure AI Search"],
        "measurement_platform": ["Profound", "Authoritas", "Custom Build"],
        "commerce_platform": ["Shopify", "Salesforce Commerce Cloud", "Adobe Commerce", "Custom"],
        "content_platform": ["Contentful", "Adobe Experience Manager", "Sanity", "Custom CMS"]
      }
    },
    "engagement": {
      "model": "{{engagement.model}}",
      "duration_weeks": "{{engagement.duration}}",
      "team_size": "{{engagement.team_size}}",
      "defaults": {
        "model": "Enterprise Governance",
        "duration_weeks": 18,
        "team_size": 12
      },
      "options": {
        "model": [
          {
            "name": "POC/Pilot",
            "duration_weeks": "8-12",
            "team_size": "4-6",
            "budget_range": "$200K-$400K"
          },
          {
            "name": "Enterprise Governance",
            "duration_weeks": "16-20",
            "team_size": "10-17",
            "budget_range": "$1.5M-$3M"
          },
          {
            "name": "Managed Services",
            "duration_weeks": "Ongoing",
            "team_size": "3-5",
            "budget_range": "$50K-$150K/month"
          }
        ]
      }
    },
    "pricing": {
      "currency": "USD",
      "rates": {
        "onshore": {
          "partner": 500,
          "director": 421,
          "senior_manager": 382,
          "manager": 347,
          "senior_consultant": 295,
          "consultant": 253
        },
        "nearshore": {
          "senior": 185,
          "mid": 145,
          "junior": 110
        },
        "offshore": {
          "senior": 95,
          "mid": 75,
          "junior": 55
        }
      }
    }
  },
  "structure": {
    "volumes": [
      {
        "id": "volume-1",
        "title": "Strategic Framework",
        "description": "Conceptual foundation and business case for GEO",
        "chapters": [
          {"id": "chapter-1", "title": "The GEO Imperative"},
          {"id": "chapter-2", "title": "Strategic Work Tracks"},
          {"id": "chapter-3", "title": "Maturity Model"}
        ]
      },
      {
        "id": "volume-2",
        "title": "Methodology Playbooks",
        "description": "Reusable patterns and execution frameworks",
        "chapters": [
          {"id": "chapter-4", "title": "Discovery & Assessment"},
          {"id": "chapter-5", "title": "Content Architecture"},
          {"id": "chapter-6", "title": "Agentic Enablement"},
          {"id": "chapter-7", "title": "Measurement & Optimization"},
          {"id": "chapter-8", "title": "Governance Operations"}
        ]
      },
      {
        "id": "volume-3",
        "title": "Delivery Execution",
        "description": "Project management and team operations",
        "chapters": [
          {"id": "chapter-9", "title": "Engagement Models"},
          {"id": "chapter-10", "title": "Team & Staffing"},
          {"id": "chapter-11", "title": "Risk & Dependencies"}
        ]
      },
      {
        "id": "volume-4",
        "title": "Reference Appendices",
        "description": "Swappable technology patterns and templates",
        "appendices": [
          {"id": "appendix-a", "title": "Technology Reference Architectures"},
          {"id": "appendix-b", "title": "Measurement Platform Options"},
          {"id": "appendix-c", "title": "Industry Templates"},
          {"id": "appendix-d", "title": "Worksheets & Templates"}
        ]
      }
    ]
  },
  "outputFormats": {
    "html": {
      "enabled": true,
      "features": ["interactive", "searchable", "responsive", "collapsible"],
      "theme": "professional-dark"
    },
    "pdf": {
      "enabled": true,
      "pageSize": "letter",
      "includeCovers": true
    },
    "slides": {
      "enabled": true,
      "maxSlides": 30,
      "chaptersToInclude": ["chapter-1", "chapter-2", "chapter-9"]
    }
  }
}
