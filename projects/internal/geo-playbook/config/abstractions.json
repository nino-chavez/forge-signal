{
  "$schema": "abstractions-schema.json",
  "version": "1.0.0",
  "source_materials": [
    "signal-forge-v3.4",
    "signal-forge-v4",
    "signal-forge-gap-analysis",
    "aeo-geo-concepts",
    "nike-proposal"
  ],
  "universal_concepts": {
    "geo_imperative": {
      "title": "The GEO Imperative",
      "core_insight": "AI is becoming the discovery layer for consumers, shifting power from traditional search to generative engines",
      "key_points": [
        "50%+ of product research queries now involve AI assistants",
        "Traditional SEO alone is insufficient for AI-era discovery",
        "Citation is the new click - being referenced by AI is the goal",
        "Pre-brand awareness queries determine which brands enter consideration"
      ],
      "source": "aeo-geo-concepts"
    },
    "citation_economy": {
      "title": "The Citation Economy",
      "core_insight": "Success is measured by citation rate and share of voice, not just traffic",
      "key_points": [
        "Direct citation: URL explicitly mentioned in AI response",
        "Implicit citation: Information used without attribution",
        "Inline attribution: 'According to [Source]...' format",
        "Citation value includes brand awareness even without clicks"
      ],
      "source": "aeo-geo-concepts"
    },
    "success_pillars": {
      "title": "GEO Success Pillars",
      "pillars": [
        {
          "name": "Brand Sentiment",
          "description": "How the brand is described and trusted across AI platforms",
          "track": "Offsite Strategy"
        },
        {
          "name": "Topical Visibility",
          "description": "Visibility in early-stage discovery for key topics",
          "track": "Offsite Strategy, Owned Ecosystem"
        },
        {
          "name": "Quality & Value",
          "description": "Accurate representation of brand attributes in LLM knowledge",
          "track": "Owned Ecosystem, Agentic Strategy"
        },
        {
          "name": "Product Discovery",
          "description": "Products surfacing in AI comparisons and recommendations",
          "track": "Owned Ecosystem, Agentic Strategy"
        }
      ],
      "source": "nike-proposal"
    }
  },
  "methodology_patterns": {
    "content_first_prompt_derivation": {
      "title": "Content-First Prompt Derivation",
      "description": "Work backwards from existing content to derive prompts the brand should rank for",
      "steps": [
        {
          "step": 1,
          "action": "Collect key landing page URLs",
          "output": "URL list (50-100 pages)",
          "details": "PDPs, category pages, blog posts, guides"
        },
        {
          "step": 2,
          "action": "Extract content semantics",
          "output": "Content corpus",
          "details": "Title, description, body text, structured data"
        },
        {
          "step": 3,
          "action": "Classify by taxonomy",
          "output": "Tagged content",
          "details": "Content Type, User Intent, Funnel Stage"
        },
        {
          "step": 4,
          "action": "Extract topics and entities",
          "output": "Topic/entity list",
          "details": "Using NLP (spaCy, KeyBERT, or similar)"
        },
        {
          "step": 5,
          "action": "Generate conversational prompts",
          "output": "Derived prompts",
          "details": "LLM expansion from topics"
        },
        {
          "step": 6,
          "action": "Validate semantic alignment",
          "output": "Match rate score",
          "details": "Prompts align with content chunks"
        }
      ],
      "source": "signal-forge-v4"
    },
    "engagement_phasing": {
      "title": "Engagement Phase Pattern",
      "phases": [
        {
          "phase": 0,
          "name": "Plan/Analyze/Design",
          "description": "Solution design and integration planning",
          "typical_duration": "2 weeks",
          "key_outputs": ["Architecture doc", "Integration contracts", "Taxonomy mapping"]
        },
        {
          "phase": 1,
          "name": "Mobilization",
          "description": "Team onboarding and artifact collection",
          "typical_duration": "1 week",
          "key_outputs": ["Team aligned", "Input artifacts collected", "Environments validated"]
        },
        {
          "phase": 2,
          "name": "Data Foundation",
          "description": "Data pipeline and storage infrastructure",
          "typical_duration": "2 weeks",
          "key_outputs": ["Ingestion pipeline working", "Vector store configured", "Sample data validated"]
        },
        {
          "phase": 3,
          "name": "Core Build",
          "description": "Primary system development",
          "typical_duration": "3 weeks",
          "key_outputs": ["Core functionality working", "Integration points validated"]
        },
        {
          "phase": 4,
          "name": "Measurement",
          "description": "Measurement and reporting infrastructure",
          "typical_duration": "2 weeks",
          "key_outputs": ["KPIs tracked", "Dashboards operational", "Baseline established"]
        },
        {
          "phase": 5,
          "name": "Integration & Polish",
          "description": "End-to-end validation and refinement",
          "typical_duration": "2 weeks",
          "key_outputs": ["E2E flow validated", "Documentation complete", "UAT passed"]
        },
        {
          "phase": 6,
          "name": "Pilot Execution",
          "description": "Live operation and measurement",
          "typical_duration": "3 weeks",
          "key_outputs": ["Pilot metrics captured", "Optimization recommendations", "Readout delivered"]
        }
      ],
      "source": "signal-forge-v3.4"
    },
    "governance_categories": {
      "title": "Governance Categories",
      "categories": [
        {
          "id": 1,
          "name": "Program & Delivery Leadership",
          "poc_approach": "Assign EM accountability to senior resource",
          "enterprise_approach": "Dedicated Delivery Lead + Track Leads"
        },
        {
          "id": 2,
          "name": "Quality Assurance & Testing",
          "poc_approach": "Testing embedded in technical roles",
          "enterprise_approach": "Dedicated QA function with test management"
        },
        {
          "id": 3,
          "name": "Change & Scope Management",
          "poc_approach": "Email-based approval, lightweight CR process",
          "enterprise_approach": "Formal CCB for major changes"
        },
        {
          "id": 4,
          "name": "Risk Management",
          "poc_approach": "Risks reviewed in weekly status",
          "enterprise_approach": "Formal risk register with mitigation tracking"
        },
        {
          "id": 5,
          "name": "Knowledge Transfer & Enablement",
          "poc_approach": "Runbook + 1 walkthrough session",
          "enterprise_approach": "Full training program + CoE establishment"
        },
        {
          "id": 6,
          "name": "Post-Go-Live Support",
          "poc_approach": "1-week hypercare",
          "enterprise_approach": "Managed services transition"
        },
        {
          "id": 7,
          "name": "Communication & Governance",
          "poc_approach": "Weekly status, RACI",
          "enterprise_approach": "Steering committee, governance board"
        }
      ],
      "source": "signal-forge-gap-analysis"
    }
  },
  "role_patterns": {
    "core_roles": [
      {
        "role": "Delivery Lead",
        "responsibility": "Overall delivery accountability, client relationship, risk management",
        "allocation_pattern": "Full-time throughout engagement"
      },
      {
        "role": "GEO Strategist",
        "responsibility": "GEO methodology, measurement design, optimization strategy",
        "allocation_pattern": "Heavy in discovery and measurement phases"
      },
      {
        "role": "Content Strategist",
        "responsibility": "Content architecture, prompt bank, taxonomy, quality assurance",
        "allocation_pattern": "Heavy in discovery and content phases"
      },
      {
        "role": "Technical Architect",
        "responsibility": "Infrastructure design, integration architecture, technical oversight",
        "allocation_pattern": "Heavy in design and build phases"
      },
      {
        "role": "AI/ML Engineer",
        "responsibility": "Agent development, LLM configuration, prompt engineering",
        "allocation_pattern": "Heavy in build phase"
      },
      {
        "role": "Data Engineer",
        "responsibility": "Data pipelines, vector store, product feed optimization",
        "allocation_pattern": "Heavy in data foundation phase"
      }
    ],
    "scaling_pattern": {
      "poc": {
        "team_size": "4-6 FTE",
        "shore_mix": "80% onshore, 20% nearshore"
      },
      "enterprise": {
        "team_size": "10-17 FTE",
        "shore_mix": "55% onshore, 45% nearshore"
      },
      "managed_services": {
        "team_size": "3-5 FTE",
        "shore_mix": "60% nearshore, 40% offshore"
      }
    },
    "source": "signal-forge-v3.4, nike-proposal"
  },
  "technology_patterns": {
    "reference_architecture": {
      "layers": [
        {
          "layer": "Ingest",
          "purpose": "Receive and normalize data from sources",
          "pattern": "Event-driven, serverless compute"
        },
        {
          "layer": "Store",
          "purpose": "Persist raw and processed data",
          "pattern": "Object storage + metadata catalog"
        },
        {
          "layer": "Index",
          "purpose": "Enable semantic search",
          "pattern": "Vector database with hybrid search"
        },
        {
          "layer": "Embed",
          "purpose": "Generate vector representations",
          "pattern": "Embedding model (cloud or self-hosted)"
        },
        {
          "layer": "Agent",
          "purpose": "Orchestrate reasoning and tool use",
          "pattern": "LLM with tool calling capabilities"
        },
        {
          "layer": "Tools",
          "purpose": "Enable specific actions",
          "pattern": "Serverless functions with specific capabilities"
        },
        {
          "layer": "API",
          "purpose": "Expose capabilities to consumers",
          "pattern": "API gateway with auth and rate limiting"
        }
      ]
    },
    "measurement_requirements": {
      "inputs": [
        "Prompt bank (400+ prompts for pilot)",
        "Competitor list (3-5 domains)",
        "API access to measurement platform"
      ],
      "outputs": [
        "Share of voice metrics",
        "Citation tracking",
        "Sentiment analysis",
        "Week-over-week delta"
      ]
    },
    "source": "signal-forge-v3.4"
  },
  "anti_patterns": {
    "content": [
      {
        "anti_pattern": "Prompt generation without content backing",
        "problem": "Tracking prompts the brand can't actually rank for",
        "solution": "Content-first prompt derivation methodology"
      },
      {
        "anti_pattern": "Optimizing for single AI platform",
        "problem": "Platform-specific optimizations may not transfer",
        "solution": "Platform-agnostic content quality + platform-specific tactics"
      }
    ],
    "delivery": [
      {
        "anti_pattern": "Skipping design phase",
        "problem": "Rework during build increases cost and timeline",
        "solution": "2-week design phase with signed architecture doc"
      },
      {
        "anti_pattern": "Compressed pilot period",
        "problem": "Insufficient measurement cycles to demonstrate impact",
        "solution": "Minimum 3-week pilot with weekly scans"
      }
    ],
    "governance": [
      {
        "anti_pattern": "No change control",
        "problem": "Scope creep without impact assessment",
        "solution": "Lightweight CR process appropriate to engagement size"
      },
      {
        "anti_pattern": "Missing knowledge transfer",
        "problem": "Client dependency on delivery team post-engagement",
        "solution": "Runbook + training + office hours"
      }
    ],
    "source": "signal-forge-gap-analysis"
  }
}
